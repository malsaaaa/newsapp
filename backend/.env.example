# News App Backend - Environment Configuration Example
# Copy this file to .env and update the values for your environment

# Server Configuration
PORT=3000
NODE_ENV=development

# MongoDB Connection
# Local Development:
#   MONGODB_URI=mongodb://localhost:27017/news_app
# 
# MongoDB Atlas (Cloud):
#   MONGODB_URI=mongodb+srv://username:password@cluster0.mongodb.net/news_app?retryWrites=true&w=majority
#
# To get MongoDB Atlas URI:
#   1. Create free account at mongodb.com/cloud/atlas
#   2. Create a cluster (M0 free tier)
#   3. Click Connect > Connect Your Application
#   4. Copy connection string and replace username/password
MONGODB_URI=mongodb://localhost:27017/news_app

# API Configuration
MAX_PAGE_SIZE=100          # Maximum articles per page (limit requests)
DEFAULT_PAGE_SIZE=20       # Default articles per page

# Feature Flags
ENABLE_DEBUG_LOGS=true     # Enable detailed logging for development
ENABLE_SAMPLE_DATA=true    # Load sample data on startup if database is empty

# CORS Configuration
CORS_ORIGIN=*              # Allow all origins for development
                           # For production: CORS_ORIGIN=https://yourdomain.com

# News Data Configuration
NEWS_CACHE_DURATION=3600   # Cache duration in seconds (1 hour)
ARTICLES_PER_FETCH=50      # Articles to fetch per request

# Rate Limiting (optional - for future implementation)
RATE_LIMIT_WINDOW_MS=900000      # 15 minutes window
RATE_LIMIT_MAX_REQUESTS=100      # Max 100 requests per window

# Environment-Specific Examples
# 
# Development (.env):
#   PORT=3000
#   NODE_ENV=development
#   MONGODB_URI=mongodb://localhost:27017/news_app
#   ENABLE_DEBUG_LOGS=true
#   ENABLE_SAMPLE_DATA=true
#
# Production (.env.production):
#   PORT=5000
#   NODE_ENV=production
#   MONGODB_URI=mongodb+srv://prod_user:secure_pass@prod_cluster.mongodb.net/news_app
#   ENABLE_DEBUG_LOGS=false
#   ENABLE_SAMPLE_DATA=false
