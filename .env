# News App Environment Configuration
# This file stores configuration values for different environments

# Backend API Configuration
BACKEND_URL=http://localhost:3000/api

# For Android Emulator, use:
# BACKEND_URL=http://10.0.2.2:3000/api

# For Physical Devices, replace with your server IP:
# BACKEND_URL=http://192.168.x.x:3000/api

# API Timeouts (in seconds)
API_TIMEOUT=10
CACHE_DURATION_HOURS=24

# Feature Flags
ENABLE_OFFLINE_MODE=true
ENABLE_ARTICLE_CACHING=true
ENABLE_IMAGE_CACHING=true
ENABLE_DETAILED_LOGS=false

# UI Configuration
ARTICLES_PER_PAGE=20
MAX_DESCRIPTION_LENGTH=200
SHOW_AUTHOR_INFO=true
SHOW_SOURCE_INFO=true
